<!DOCTYPE html>
<html lang="nl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Warehouse</title>

    <link rel="stylesheet" href="~/css/dashboard.css" asp-append-version="true" />
</head>
<body>
    <div class="dashboard-layout">
        <aside class="sidebar">
            <div>
                <div class="sidebar-logo">Warehouse</div>

                <nav class="sidebar-nav">
                    <a asp-controller="Home" asp-action="Index" class="nav-item active">
                        <span class="nav-icon">▦</span>
                        <span class="nav-text">Dashboard</span>
                    </a>
                    <a asp-controller="Magazijn" asp-action="Detail" asp-route-id="1" class="nav-item">
                        <span class="nav-icon">🏠</span>
                        <span class="nav-text">Warehouse 1</span>
                    </a>
                    <a asp-controller="Magazijn" asp-action="Detail" asp-route-id="2" class="nav-item">
                        <span class="nav-icon">📦</span>
                        <span class="nav-text">Warehouse 2</span>
                    </a>
                    <a asp-controller="Shop" asp-action="Index" class="nav-item">
                        <span class="nav-icon">🛒</span>
                        <span class="nav-text">Shop</span>
                    </a>
                </nav>
            </div>

            <div class="sidebar-bottom">
                <a asp-controller="Account" asp-action="Logout" class="logout-link">
                    <span class="logout-icon">↪</span>
                    <span class="logout-text">Logout</span>
                </a>
            </div>
        </aside>

        <main class="main-content">
            @RenderBody()
        </main>
    </div>
</body>
</html>