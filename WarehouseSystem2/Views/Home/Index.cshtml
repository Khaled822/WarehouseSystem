@{
    ViewData["Title"] = "Dashboard Overzicht";
}

<!-- TOPBAR -->
<div class="topbar">
    <div class="search-box">
        <input type="text" placeholder="Zoeken..." />
    </div>
</div>

<!-- STATS -->
<div class="overview-stats">
    <div class="stat-card">
        <div class="s-label">Totale producten</div>
        <div class="s-value">124</div>
        <div class="s-sub">Inventaris</div>
    </div>
    <div class="stat-card">
        <div class="s-label">Medewerkers</div>
        <div class="s-value">12</div>
        <div class="s-sub">Actieve staff</div>
    </div>
    <div class="stat-card">
        <div class="s-label">Saldo</div>
        <div class="s-value">€5.000</div>
        <div class="s-sub">Huidig budget</div>
    </div>
    <div class="stat-card">
        <div class="s-label">Magazijnen</div>
        <div class="s-value">2</div>
        <div class="s-sub">Locaties</div>
    </div>
</div>

<!-- HEADER -->
<div class="section-header">
    <h2>Dashboard Overzicht</h2>
    <a href="#" class="section-link">Alle locaties</a>
</div>

<!-- MAGAZIJNEN -->
<div class="warehouse-grid">
    <div class="warehouse-card">
        <div class="wh-top">
            <div class="wh-icon-box">📦</div>
            <span class="wh-badge">Actief</span>
        </div>

        <div class="wh-name">Magazijn 1</div>
        <div class="wh-loc">Industrieweg 12, Rotterdam</div>

        <div class="wh-stats">
            <div class="wh-stat">
                <div class="lbl">PRODUCTEN</div>
                <div class="val">84</div>
            </div>
            <div class="wh-stat">
                <div class="lbl">STAFF</div>
                <div class="val">7</div>
            </div>
            <div class="wh-stat">
                <div class="lbl">CAPACITEIT</div>
                <div class="val">82%</div>
            </div>
        </div>

        <a href="/Magazijn/Detail/1" class="btn-view">Bekijken</a>
    </div>

    <div class="warehouse-card">
        <div class="wh-top">
            <div class="wh-icon-box">🏭</div>
            <span class="wh-badge">Actief</span>
        </div>

        <div class="wh-name">Magazijn 2</div>
        <div class="wh-loc">Havengebied 45, Antwerpen</div>

        <div class="wh-stats">
            <div class="wh-stat">
                <div class="lbl">PRODUCTEN</div>
                <div class="val">40</div>
            </div>
            <div class="wh-stat">
                <div class="lbl">STAFF</div>
                <div class="val">5</div>
            </div>
            <div class="wh-stat">
                <div class="lbl">CAPACITEIT</div>
                <div class="val">65%</div>
            </div>
        </div>

        <a href="/Magazijn/Detail/2" class="btn-view">Bekijken</a>
    </div>
</div>

<!-- ONDERSTE DEEL -->
<div class="bottom-grid">
    <div class="activity-section">
        <h3>Recente Activiteit</h3>

        <div class="activity-list">
            <div class="activity-item">
                <div class="activity-icon">📁</div>
                <div>
                    <div class="activity-title">Nieuwe product toegevoegd aan Magazijn 1</div>
                    <div class="activity-time">14 minuten geleden</div>
                </div>
            </div>

            <div class="activity-item">
                <div class="activity-icon">👤</div>
                <div>
                    <div class="activity-title">Nieuwe medewerker toegevoegd aan Magazijn 2</div>
                    <div class="activity-time">2 uur geleden</div>
                </div>
            </div>
        </div>
    </div>

    <div class="quicklinks-section">
        <h3>Snelkoppelingen</h3>

        <div class="quicklinks">
            <a href="#" class="quicklink">➕ Nieuw Prodeuct</a>
            <a href="#" class="quicklink">👥 Nieuwee Stafvf</a>
            <a href="#" class="quicklink active">🏠 Nieuw Magazijnn</a>
        </div>
    </div>
</div>